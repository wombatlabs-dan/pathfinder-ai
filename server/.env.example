# Neo4j Aura Configuration
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# LLM Configuration (OpenAI-compatible API)
# Works with OpenAI, DeepSeek via GMI Cloud, Anthropic, or any OpenAI-compatible provider
# Accepts LLM_API_KEY or OPENAI_API_KEY (for backward compatibility)
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Example: DeepSeek V3.2 via GMI Cloud (used during hackathon build)
# LLM_API_KEY=your-gmi-api-key
# LLM_BASE_URL=https://api.gmi-serving.com/v1
# LLM_MODEL=deepseek-ai/DeepSeek-V3.2

# RocketRide Pipeline (optional — set when pipeline is running in Antigravity)
# ROCKETRIDE_WEBHOOK_URL=http://localhost:57112/webhook/pathfinder

# Server Configuration
PORT=3001
NODE_ENV=development
